{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "server",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-26",
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "<your-kv-namespace-id>",
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "game-sales-tracker",
      "database_id": "<your-d1-database-id>",
    },
  ],
}
